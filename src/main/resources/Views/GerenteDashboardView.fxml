<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="br.edu.ufersa.LibreFox.Controller.GerenteDashboardController"
      stylesheets="@../CSS/style.css" styleClass="painel-principal">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox spacing="20" VBox.vgrow="ALWAYS">

        <!-- MENU LATERAL -->
        <VBox styleClass="painel-lateral" spacing="6" minWidth="220" prefWidth="220">
            <VBox spacing="2" alignment="CENTER">
                <padding>
                    <Insets bottom="20"/>
                </padding>
                <Label text="LibreFox" styleClass="logo-texto"/>
                <Label text="Gestão de editoras" styleClass="logo-subtexto"/>
            </VBox>

            <Label text="MENU" styleClass="label-menu-secao"/>

            <Button fx:id="btnHome" text="Página principal" styleClass="btn-lateral, btn-lateral-ativo"
                    maxWidth="Infinity" onAction="#navegarHome">
                <graphic><ImageView fitWidth="18" fitHeight="18" preserveRatio="true">
                    <image><Image url="@../Images/home.png"/></image></ImageView></graphic>
            </Button>
            <Button fx:id="btnAutores" text="Gerenciar autores" styleClass="btn-lateral"
                    maxWidth="Infinity" onAction="#navegarAutores">
                <graphic><ImageView fitWidth="18" fitHeight="18" preserveRatio="true">
                    <image><Image url="@../Images/autores.png"/></image></ImageView></graphic>
            </Button>
            <Button fx:id="btnAvaliadores" text="Gerenciar avaliadores" styleClass="btn-lateral"
                    maxWidth="Infinity" onAction="#navegarAvaliadores">
                <graphic><ImageView fitWidth="18" fitHeight="18" preserveRatio="true">
                    <image><Image url="@../Images/avaliadores.png"/></image></ImageView></graphic>
            </Button>
            <Button fx:id="btnObras" text="Gerenciar obra" styleClass="btn-lateral"
                    maxWidth="Infinity" onAction="#navegarObras">
                <graphic><ImageView fitWidth="18" fitHeight="18" preserveRatio="true">
                    <image><Image url="@../Images/obras.png"/></image></ImageView></graphic>
            </Button>
            <Button fx:id="btnRelatorios" text="Relatórios" styleClass="btn-lateral"
                    maxWidth="Infinity" onAction="#navegarRelatorios">
                <graphic><ImageView fitWidth="18" fitHeight="18" preserveRatio="true">
                    <image><Image url="@../Images/relatorio.png"/></image></ImageView></graphic>
            </Button>

            <VBox spacing="4" VBox.vgrow="ALWAYS"/>

            <HBox alignment="CENTER">
                <Button fx:id="btnTrocarPerfil" text="Trocar perfil" styleClass="btn-lateral"
                        maxWidth="Infinity" onAction="#handleTrocarPerfil"
                        visible="false" managed="false"/>
            </HBox>

            <HBox alignment="CENTER">
                <Button fx:id="btnSair" text="Sair" styleClass="btn-sair"
                        onAction="#handleSair">
                    <graphic><ImageView fitWidth="18" fitHeight="18" preserveRatio="true">
                        <image><Image url="@../Images/sair.png"/></image></ImageView></graphic>
                </Button>
            </HBox>
        </VBox>

        <!-- CONTEÚDO PRINCIPAL -->
        <VBox spacing="16" HBox.hgrow="ALWAYS" styleClass="painel-branco">
            <padding>
                <Insets top="24" right="28" bottom="24" left="28"/>
            </padding>

            <!-- CABEÇALHO -->
            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox>
                    <Label fx:id="lblSaudacao" styleClass="label-saudacao" text="Olá, Gerente!"/>
                    <Label styleClass="label-descricao" text="Aqui está o resumo da sua editora"/>
                </VBox>
                <HBox HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnNotificacoes" text="🔔" styleClass="btn-secundario"
                        onAction="#handleNotificacoes" visible="false" managed="false"/>
            </HBox>

            <!-- CARDS DE RESUMO -->
            <HBox spacing="16" alignment="CENTER">
                <VBox styleClass="card-resumo" HBox.hgrow="ALWAYS">
                    <Label text="Obras em avaliação" styleClass="label-rotulo"/>
                    <Label fx:id="lblEmAvaliacao" text="0" styleClass="label-valor"/>
                </VBox>
                <VBox styleClass="card-resumo" HBox.hgrow="ALWAYS">
                    <Label text="Obras aceitas" styleClass="label-rotulo"/>
                    <Label fx:id="lblAceitas" text="0" styleClass="label-valor"/>
                </VBox>
                <VBox styleClass="card-resumo" HBox.hgrow="ALWAYS">
                    <Label text="Obras rejeitadas" styleClass="label-rotulo"/>
                    <Label fx:id="lblRejeitadas" text="0" styleClass="label-valor"/>
                </VBox>
                <VBox styleClass="card-resumo" HBox.hgrow="ALWAYS">
                    <Label text="Obras sem avaliador" styleClass="label-rotulo"/>
                    <Label fx:id="lblSemAvaliador" text="0" styleClass="label-valor"/>
                </VBox>
            </HBox>

            <!-- AVALIAÇÕES PENDENTES -->
            <VBox spacing="8">
                <Label text="📋 Avaliações pendentes" styleClass="titulo-subsecao"/>
                <VBox spacing="4" styleClass="painel-cinza" maxHeight="150">
                    <Label fx:id="lblPendencia1" text="Nenhuma pendência"
                           style="-fx-padding: 6 12; -fx-font-size: 13px;"/>
                    <Label fx:id="lblPendencia2" text=""
                           style="-fx-padding: 6 12; -fx-font-size: 13px;"/>
                    <Label fx:id="lblPendencia3" text=""
                           style="-fx-padding: 6 12; -fx-font-size: 13px;"/>
                </VBox>
            </VBox>

            <!-- ÚLTIMAS OBRAS -->
            <VBox spacing="8" VBox.vgrow="ALWAYS">
                <Label text="📚 Últimas obras cadastradas" styleClass="titulo-subsecao"/>

                <TableView fx:id="tblObras" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colTitulo" text="Obra" prefWidth="250"/>
                        <TableColumn fx:id="colAutor" text="Autor" prefWidth="150"/>
                        <TableColumn fx:id="colStatus" text="Status" prefWidth="120"/>
                        <TableColumn fx:id="colAcoes" text="Ações" prefWidth="150"/>
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </HBox>
</VBox>
