<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml"
      fx:controller="br.edu.ufersa.LibreFox.Controller.RelatoriosController"
      stylesheets="@../CSS/style.css" styleClass="painel-principal">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox spacing="20" VBox.vgrow="ALWAYS">

        <!-- MENU LATERAL -->
        <VBox styleClass="painel-lateral" spacing="6" minWidth="220" prefWidth="220">
            <VBox spacing="2" alignment="CENTER">
                <padding>
                    <Insets bottom="20"/>
                </padding>
                <Label text="LibreFox" styleClass="logo-texto"/>
                <Label text="Gestão de editoras" styleClass="logo-subtexto"/>
            </VBox>

            <Label text="MENU" styleClass="label-menu-secao"/>

            <Button text="🏠 Página principal" styleClass="btn-lateral" maxWidth="Infinity" onAction="#navegarHome"/>
            <Button text="👤 Gerenciar autores" styleClass="btn-lateral" maxWidth="Infinity" onAction="#navegarAutores"/>
            <Button text="⭐ Gerenciar avaliadores" styleClass="btn-lateral" maxWidth="Infinity" onAction="#navegarAvaliadores"/>
            <Button text="📚 Gerenciar obra" styleClass="btn-lateral" maxWidth="Infinity" onAction="#navegarObras"/>
            <Button text="📊 Relatórios" styleClass="btn-lateral, btn-lateral-ativo" maxWidth="Infinity"/>

            <VBox spacing="4" VBox.vgrow="ALWAYS"/>

            <HBox alignment="CENTER">
                <Button text="🚪 Sair" styleClass="btn-sair" onAction="#handleSair"/>
            </HBox>
        </VBox>

        <!-- CONTEÚDO PRINCIPAL -->
        <VBox spacing="16" HBox.hgrow="ALWAYS" styleClass="painel-branco">
            <padding>
                <Insets top="24" right="28" bottom="24" left="28"/>
            </padding>

            <Label text="📊 Relatórios" styleClass="titulo-principal"/>

            <!-- FILTROS DO RELATÓRIO -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <VBox spacing="2">
                    <Label text="Data inicial" style="-fx-font-size: 12px; -fx-text-fill: #6c757d;"/>
                    <DatePicker fx:id="dtpDataInicial" styleClass="campo-texto"/>
                </VBox>
                <VBox spacing="2">
                    <Label text="Data final" style="-fx-font-size: 12px; -fx-text-fill: #6c757d;"/>
                    <DatePicker fx:id="dtpDataFinal" styleClass="campo-texto"/>
                </VBox>
                <VBox spacing="2">
                    <Label text="Avaliador" style="-fx-font-size: 12px; -fx-text-fill: #6c757d;"/>
                    <ComboBox fx:id="cmbAvaliador" promptText="Todos" maxWidth="200"/>
                </VBox>
                <Button text="📊 Gerar relatório" styleClass="btn-primario" onAction="#handleGerarRelatorio"/>
                <Button text="📥 Exportar" styleClass="btn-secundario" onAction="#handleExportar"/>
            </HBox>

            <!-- CARDS DE RESUMO DO RELATÓRIO -->
            <HBox spacing="16" alignment="CENTER">
                <VBox styleClass="card-resumo" HBox.hgrow="ALWAYS">
                    <Label text="Total de obras" styleClass="label-rotulo"/>
                    <Label fx:id="lblTotalObras" text="0" styleClass="label-valor"/>
                </VBox>
                <VBox styleClass="card-resumo" HBox.hgrow="ALWAYS">
                    <Label text="Aprovadas" styleClass="label-rotulo"/>
                    <Label fx:id="lblAprovadas" text="0" styleClass="label-valor" style="-fx-text-fill: #28a745;"/>
                </VBox>
                <VBox styleClass="card-resumo" HBox.hgrow="ALWAYS">
                    <Label text="Rejeitadas" styleClass="label-rotulo"/>
                    <Label fx:id="lblRejeitadas" text="0" styleClass="label-valor" style="-fx-text-fill: #dc3545;"/>
                </VBox>
            </HBox>

            <!-- TABELA DO RELATÓRIO -->
            <TableView fx:id="tblRelatorio" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colTitulo" text="Título" prefWidth="200"/>
                    <TableColumn fx:id="colAutor" text="Autor" prefWidth="150"/>
                    <TableColumn fx:id="colGenero" text="Gênero" prefWidth="120"/>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="120"/>
                    <TableColumn fx:id="colDataAvaliacao" text="Data avaliação" prefWidth="150"/>
                    <TableColumn fx:id="colAvaliador" text="Avaliador" prefWidth="150"/>
                </columns>
            </TableView>
        </VBox>
    </HBox>
</VBox>
