<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="br.edu.ufersa.LibreFox.Controller.GerenciarObrasController"
      stylesheets="@../CSS/style.css" styleClass="painel-principal">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox spacing="20" VBox.vgrow="ALWAYS">

        <!-- MENU LATERAL -->
        <VBox styleClass="painel-lateral" spacing="6" minWidth="220" prefWidth="220">
            <VBox spacing="2" alignment="CENTER">
                <padding>
                    <Insets bottom="20"/>
                </padding>
                <Label text="LibreFox" styleClass="logo-texto"/>
                <Label text="Gestão de editoras" styleClass="logo-subtexto"/>
            </VBox>

            <Label text="MENU" styleClass="label-menu-secao"/>

            <Button text="🏠 Página principal" styleClass="btn-lateral" maxWidth="Infinity" onAction="#navegarHome"/>
            <Button text="👤 Gerenciar autores" styleClass="btn-lateral" maxWidth="Infinity" onAction="#navegarAutores"/>
            <Button text="⭐ Gerenciar avaliadores" styleClass="btn-lateral" maxWidth="Infinity" onAction="#navegarAvaliadores"/>
            <Button text="📚 Gerenciar obra" styleClass="btn-lateral, btn-lateral-ativo" maxWidth="Infinity"/>
            <Button text="📊 Relatórios" styleClass="btn-lateral" maxWidth="Infinity" onAction="#navegarRelatorios"/>

            <VBox spacing="4" VBox.vgrow="ALWAYS"/>

            <HBox alignment="CENTER">
                <Button text="🚪 Sair" styleClass="btn-sair" onAction="#handleSair"/>
            </HBox>
        </VBox>

        <!-- CONTEÚDO PRINCIPAL -->
        <VBox spacing="16" HBox.hgrow="ALWAYS" styleClass="painel-branco">
            <padding>
                <Insets top="24" right="28" bottom="24" left="28"/>
            </padding>

            <Label text="📚 Gerenciar obras" styleClass="titulo-principal"/>

            <!-- FILTROS -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <TextField fx:id="campoBusca" promptText="Nome ou obra..." styleClass="campo-busca"
                           maxWidth="250"/>
                <ComboBox fx:id="cmbStatus" promptText="Status" maxWidth="150"/>
                <ComboBox fx:id="cmbAno" promptText="Ano" maxWidth="120"/>
                <Button text="🔍 Buscar" styleClass="btn-azul-claro" onAction="#handleBuscar"/>
                <HBox HBox.hgrow="ALWAYS"/>
                <Button text="➕ Nova obra" styleClass="btn-primario" onAction="#handleNovaObra"/>
            </HBox>

            <TableView fx:id="tblObras" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colTitulo" text="Título" prefWidth="200"/>
                    <TableColumn fx:id="colAutor" text="Autor" prefWidth="150"/>
                    <TableColumn fx:id="colGenero" text="Gênero" prefWidth="120"/>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="120"/>
                    <TableColumn fx:id="colAno" text="Ano" prefWidth="80"/>
                    <TableColumn fx:id="colAvaliador" text="Avaliador" prefWidth="150"/>
                    <TableColumn fx:id="colAcoes" text="Ações" prefWidth="120"/>
                </columns>
            </TableView>
        </VBox>
    </HBox>
</VBox>
