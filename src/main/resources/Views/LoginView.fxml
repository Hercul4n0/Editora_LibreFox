<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Text?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="br.edu.ufersa.LibreFox.Controller.LoginController"
           stylesheets="@../CSS/style.css">

    <VBox alignment="CENTER" styleClass="painel-login" spacing="0" prefWidth="1200"
          prefHeight="800">
        <HBox alignment="CENTER" spacing="0" prefWidth="900"
              prefHeight="560"
              VBox.vgrow="NEVER">

            <!-- LADO ESQUERDO - LOGO -->
            <VBox alignment="CENTER" spacing="20" styleClass="painel-login-esquerdo"
                  HBox.hgrow="ALWAYS" minWidth="420" prefWidth="420" maxWidth="420">
                <Text styleClass="logo-texto" text="LibreFox" fill="white"/>
                <Text styleClass="logo-subtexto" text="Gestão de editoras simplificada"
                      fill="#c8b8d8"/>

                <VBox alignment="CENTER" spacing="8" maxWidth="280">
                    <padding>
                        <Insets top="16"/>
                    </padding>
                    <Label text="Gerencie autores, avaliadores e obras em um só lugar"
                           style="-fx-text-fill: #d6c4e0; -fx-font-size: 13px; -fx-wrap-text: true;"
                           alignment="CENTER" textAlignment="CENTER"/>
                </VBox>
            </VBox>

            <!-- LADO DIREITO - FORMULÁRIO DE LOGIN -->
            <VBox alignment="CENTER" spacing="20" styleClass="painel-login-direito"
                  HBox.hgrow="ALWAYS" minWidth="420" prefWidth="420" maxWidth="420">
                <padding>
                    <Insets top="40" right="40" bottom="40" left="40"/>
                </padding>

                <VBox alignment="CENTER" spacing="2">
                    <Label text="LibreFox" styleClass="logo-texto-claro"/>
                    <Label text="Gestão de editoras simplificada" styleClass="logo-subtexto-claro"/>
                </VBox>

                <VBox alignment="CENTER" spacing="4">
                    <Label text="Faça login na sua conta" styleClass="titulo-login"/>
                    <Label text="Bem-vindo de volta" styleClass="label-descricao"/>
                </VBox>

                <VBox spacing="14" maxWidth="340">
                    <!-- E-mail -->
                    <VBox spacing="4">
                        <Label text="E-mail" style="-fx-font-weight: 600; -fx-text-fill: #333;"/>
                        <TextField fx:id="campoLogin" promptText="Digite seu e-mail"
                                   styleClass="campo-texto"/>
                    </VBox>

                    <!-- Senha -->
                    <VBox spacing="4">
                        <Label text="Senha" style="-fx-font-weight: 600; -fx-text-fill: #333;"/>
                        <PasswordField fx:id="campoSenha" promptText="Digite sua senha"
                                       styleClass="campo-texto"/>
                    </VBox>

                    <!-- Seletor de Perfil (DEBUG) -->
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="Perfil:" style="-fx-font-weight: 600; -fx-text-fill: #333;"/>
                        <Button fx:id="btnPerfilAutor" text="Autor" styleClass="btn-azul-claro"
                                onAction="#selecionarPerfil"/>
                        <Button fx:id="btnPerfilAvaliador" text="Avaliador" styleClass="btn-azul-claro"
                                onAction="#selecionarPerfil"/>
                        <Button fx:id="btnPerfilGerente" text="Gerente" styleClass="btn-azul-claro"
                                onAction="#selecionarPerfil"/>
                    </HBox>

                    <Label fx:id="lblMensagemErro" styleClass="msg-erro" wrapText="true"/>

                    <Button text="Entrar" styleClass="btn-primario" maxWidth="Infinity"
                            onAction="#handleLogin"/>

                    <HBox alignment="CENTER" spacing="4">
                        <Label text="Novo no LibreFox?" styleClass="label-descricao"/>
                        <Hyperlink text="Crie uma conta!" onAction="#handleIrCadastro"/>
                    </HBox>
                </VBox>
            </VBox>
        </HBox>
    </VBox>
</StackPane>
