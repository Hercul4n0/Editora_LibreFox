<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="br.edu.ufersa.LibreFox.Controller.AutorDashboardController"
      stylesheets="@style.css" styleClass="painel-principal">

    <HBox spacing="0" VBox.vgrow="ALWAYS">

        <!-- MENU LATERAL -->
        <VBox styleClass="painel-lateral" spacing="8" minWidth="200" prefWidth="200">
            <VBox spacing="4" alignment="CENTER" padding="0 0 20 0">
                <Label text="LibreFox" styleClass="logo-texto"/>
                <Label text="Gestão de editoras" styleClass="logo-subtexto"/>
            </VBox>

            <Label text="MENU" style="-fx-text-fill: #6c6c80; -fx-font-size: 11px; -fx-font-weight: 600; -fx-padding: 10 0 4 0;"/>

            <Button fx:id="btnHome" text="🏠 Página principal" styleClass="btn-lateral, btn-lateral-ativo"
                    onAction="#navegarHome"/>
            <Button fx:id="btnMinhasObras" text="📚 Minhas obras" styleClass="btn-lateral"
                    onAction="#navegarMinhasObras"/>

            <VBox spacing="4" VBox.vgrow="ALWAYS"/>

            <Button fx:id="btnSair" text="🚪 Sair" styleClass="btn-sair" maxWidth="Infinity"
                    onAction="#handleSair"/>
        </VBox>

        <!-- CONTEÚDO PRINCIPAL -->
        <VBox spacing="16" HBox.hgrow="ALWAYS" styleClass="painel-branco"
              padding="20 24">

            <!-- CABEÇALHO -->
            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox>
                    <Label styleClass="label-saudacao" fx:id="lblSaudacao" text="Olá, Jonas Emanuel!"/>
                    <Label styleClass="label-descricao" text="Acompanhe suas obras"/>
                </VBox>
                <HBox HBox.hgrow="ALWAYS"/>
                <Button text="➕ Nova obra" styleClass="btn-primario" onAction="#handleNovaObra"/>
            </HBox>

            <!-- CARDS DE RESUMO -->
            <HBox spacing="16" alignment="CENTER">
                <VBox styleClass="card-resumo" HBox.hgrow="ALWAYS">
                    <Label text="Obras em avaliação" styleClass="label-rotulo"/>
                    <Label fx:id="lblEmAvaliacao" text="0" styleClass="label-valor"/>
                </VBox>
                <VBox styleClass="card-resumo" HBox.hgrow="ALWAYS">
                    <Label text="Obras aceitas" styleClass="label-rotulo"/>
                    <Label fx:id="lblAceitas" text="0" styleClass="label-valor"/>
                </VBox>
                <VBox styleClass="card-resumo" HBox.hgrow="ALWAYS">
                    <Label text="Obras rejeitadas" styleClass="label-rotulo"/>
                    <Label fx:id="lblRejeitadas" text="0" styleClass="label-valor"/>
                </VBox>
            </HBox>

            <!-- MINHAS OBRAS -->
            <VBox spacing="8" VBox.vgrow="ALWAYS">
                <Label text="📚 Minhas obras" styleClass="titulo-subsecao"/>

                <!-- Campo de busca -->
                <TextField fx:id="campoBusca" promptText="Buscar obras..." styleClass="campo-busca"
                           maxWidth="300"/>

                <TableView fx:id="tblObras" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colTitulo" text="Título" prefWidth="200"/>
                        <TableColumn fx:id="colAno" text="Ano" prefWidth="80"/>
                        <TableColumn fx:id="colGenero" text="Gênero" prefWidth="120"/>
                        <TableColumn fx:id="colStatus" text="Status" prefWidth="120"/>
                        <TableColumn fx:id="colFeedback" text="Feedback" prefWidth="150"/>
                        <TableColumn fx:id="colAcoes" text="Ações" prefWidth="100"/>
                    </columns>
                </TableView>

                <Label text="Isso é tudo por enquanto ..." style="-fx-text-fill: #6c757d; -fx-font-size: 13px;"/>
            </VBox>
        </VBox>
    </HBox>
</VBox>