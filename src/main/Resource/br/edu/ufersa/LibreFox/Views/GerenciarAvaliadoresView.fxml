<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/20" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="br.edu.ufersa.LibreFox.Controller.GerenciarAvaliadoresController"
      stylesheets="@style.css" styleClass="painel-principal">

    <HBox spacing="0" VBox.vgrow="ALWAYS">

        <!-- MENU LATERAL -->
        <VBox styleClass="painel-lateral" spacing="8" minWidth="220" prefWidth="220">
            <VBox spacing="4" alignment="CENTER" padding="0 0 20 0">
                <Label text="LibreFox" styleClass="logo-texto"/>
                <Label text="Gestão de editoras" styleClass="logo-subtexto"/>
            </VBox>

            <Label text="MENU" style="-fx-text-fill: #6c6c80; -fx-font-size: 11px; -fx-font-weight: 600; -fx-padding: 10 0 4 0;"/>

            <Button text="🏠 Página principal" styleClass="btn-lateral" onAction="#navegarHome"/>
            <Button text="👤 Gerenciar autores" styleClass="btn-lateral" onAction="#navegarAutores"/>
            <Button text="⭐ Gerenciar avaliadores" styleClass="btn-lateral, btn-lateral-ativo"/>
            <Button text="📚 Gerenciar obra" styleClass="btn-lateral" onAction="#navegarObras"/>
            <Button text="📊 Relatórios" styleClass="btn-lateral" onAction="#navegarRelatorios"/>

            <VBox spacing="4" VBox.vgrow="ALWAYS"/>

            <Button text="🚪 Sair" styleClass="btn-sair" maxWidth="Infinity" onAction="#handleSair"/>
        </VBox>

        <!-- CONTEÚDO PRINCIPAL -->
        <VBox spacing="16" HBox.hgrow="ALWAYS" styleClass="painel-branco"
              padding="20 24">

            <Label text="⭐ Gerenciar avaliadores" styleClass="titulo-principal"/>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <TextField fx:id="campoBusca" promptText="Buscar avaliadores..." styleClass="campo-busca"
                           maxWidth="300"/>
                <Button text="🔍 Buscar" styleClass="btn-azul-claro" onAction="#handleBuscar"/>
                <HBox HBox.hgrow="ALWAYS"/>
                <Button text="➕ Novo avaliador" styleClass="btn-primario" onAction="#handleNovoAvaliador"/>
            </HBox>

            <TableView fx:id="tblAvaliadores" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colNome" text="Nome" prefWidth="180"/>
                    <TableColumn fx:id="colCpf" text="CPF" prefWidth="150"/>
                    <TableColumn fx:id="colEndereco" text="Endereço" prefWidth="200"/>
                    <TableColumn fx:id="colObrasAtribuidas" text="Obras atribuídas" prefWidth="120"/>
                    <TableColumn fx:id="colAcoes" text="Ações" prefWidth="150"/>
                </columns>
            </TableView>

            <Label text="Isso é tudo por enquanto ..." style="-fx-text-fill: #6c757d; -fx-font-size: 13px;"/>
        </VBox>
    </HBox>
</VBox>