<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Text?>

<StackPane xmlns="http://javafx.com/javafx/20" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="br.edu.ufersa.LibreFox.Controller.CadastroController"
           stylesheets="@style.css">

    <VBox alignment="CENTER" styleClass="painel-login" spacing="0">
        <HBox alignment="CENTER" spacing="0" maxWidth="1000" maxHeight="650">

            <!-- LADO ESQUERDO -->
            <VBox alignment="CENTER" spacing="20" styleClass="painel-login-esquerdo"
                  HBox.hgrow="ALWAYS" minWidth="400" prefWidth="500">
                <Rectangle width="80" height="80" arcWidth="16" arcHeight="16"
                           fill="white" opacity="0.1"/>
                <Text styleClass="logo-texto" text="LibreFox" fill="white"/>
                <Text styleClass="logo-subtexto" text="Gestão de editoras simplificada"
                      fill="#a8a8b8"/>
            </VBox>

            <!-- LADO DIREITO - CADASTRO -->
            <VBox alignment="CENTER" spacing="20" styleClass="painel-login-direito"
                  HBox.hgrow="ALWAYS" minWidth="400" prefWidth="500"
                  padding="32 40">

                <VBox alignment="CENTER" spacing="4">
                    <Label text="Crie sua conta" styleClass="titulo-login"/>
                    <Label text="Comece a gerenciar suas obras" styleClass="label-descricao"/>
                </VBox>

                <VBox spacing="12" maxWidth="380">
                    <!-- Nome -->
                    <VBox spacing="3">
                        <Label text="Nome completo" style="-fx-font-weight: 500; -fx-text-fill: #333;"/>
                        <TextField fx:id="campoNome" promptText="Digite seu nome completo"
                                   styleClass="campo-texto"/>
                    </VBox>

                    <!-- E-mail -->
                    <VBox spacing="3">
                        <Label text="E-mail" style="-fx-font-weight: 500; -fx-text-fill: #333;"/>
                        <TextField fx:id="campoEmail" promptText="Digite seu e-mail"
                                   styleClass="campo-texto"/>
                    </VBox>

                    <!-- Senha -->
                    <VBox spacing="3">
                        <Label text="Senha" style="-fx-font-weight: 500; -fx-text-fill: #333;"/>
                        <PasswordField fx:id="campoSenha" promptText="Digite sua senha"
                                       styleClass="campo-texto"/>
                    </VBox>

                    <!-- Seletor de Perfil -->
                    <VBox spacing="3">
                        <Label text="Tipo de conta" style="-fx-font-weight: 500; -fx-text-fill: #333;"/>
                        <HBox spacing="8">
                            <Button fx:id="btnPerfilAutor" text="Autor" styleClass="btn-azul-claro"
                                    onAction="#selecionarPerfil"/>
                            <Button fx:id="btnPerfilAvaliador" text="Avaliador" styleClass="btn-azul-claro"
                                    onAction="#selecionarPerfil"/>
                            <Button fx:id="btnPerfilGerente" text="Gerente" styleClass="btn-azul-claro"
                                    onAction="#selecionarPerfil"/>
                        </HBox>
                    </VBox>

                    <Label fx:id="lblMensagem" styleClass="msg-erro" wrapText="true"/>

                    <Button text="Criar conta" styleClass="btn-primario" maxWidth="Infinity"
                            onAction="#handleCadastro"/>

                    <HBox alignment="CENTER" spacing="4">
                        <Label text="Já tem uma conta?" styleClass="label-descricao"/>
                        <Hyperlink text="Fazer login" onAction="#handleIrLogin"/>
                    </HBox>
                </VBox>
            </VBox>
        </HBox>
    </VBox>
</StackPane>