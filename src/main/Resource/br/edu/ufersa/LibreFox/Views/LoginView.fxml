<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Text?>

<StackPane xmlns="http://javafx.com/javafx/20" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="br.edu.ufersa.LibreFox.Controller.LoginController"
           stylesheets="@style.css">

    <VBox alignment="CENTER" styleClass="painel-login" spacing="0">
        <HBox alignment="CENTER" spacing="0" maxWidth="1000" maxHeight="600"
              VBox.vgrow="ALWAYS">

            <!-- LADO ESQUERDO - ILUSTRAÇÃO/LOGO -->
            <VBox alignment="CENTER" spacing="20" styleClass="painel-login-esquerdo"
                  HBox.hgrow="ALWAYS" minWidth="400" prefWidth="500">
                <Rectangle width="80" height="80" arcWidth="16" arcHeight="16"
                           fill="white" opacity="0.1"/>
                <Text styleClass="logo-texto" text="LibreFox" fill="white"/>
                <Text styleClass="logo-subtexto" text="Gestão de editoras simplificada"
                      fill="#a8a8b8"/>

                <VBox alignment="CENTER" spacing="8" styleClass="painel-cinza"
                      maxWidth="300" opacity="0.6">
                    <Label text="🔍" style="-fx-font-size: 24px;"/>
                    <Label text="Gerencie autores, avaliadores e obras em um só lugar"
                           style="-fx-text-fill: #c8c8d8; -fx-font-size: 13px; -fx-wrap-text: true;"
                           alignment="CENTER"/>
                </VBox>
            </VBox>

            <!-- LADO DIREITO - FORMULÁRIO DE LOGIN -->
            <VBox alignment="CENTER" spacing="24" styleClass="painel-login-direito"
                  HBox.hgrow="ALWAYS" minWidth="400" prefWidth="500"
                  padding="48 40">

                <VBox alignment="CENTER" spacing="4">
                    <Label text="Bem-vindo de volta" styleClass="label-descricao"/>
                    <Label text="Faça login na sua conta" styleClass="titulo-login"/>
                </VBox>

                <VBox spacing="16" maxWidth="360">
                    <!-- E-mail -->
                    <VBox spacing="4">
                        <Label text="E-mail" style="-fx-font-weight: 500; -fx-text-fill: #333;"/>
                        <TextField fx:id="campoLogin" promptText="Digite seu e-mail"
                                   styleClass="campo-texto"/>
                    </VBox>

                    <!-- Senha -->
                    <VBox spacing="4">
                        <Label text="Senha" style="-fx-font-weight: 500; -fx-text-fill: #333;"/>
                        <PasswordField fx:id="campoSenha" promptText="Digite sua senha"
                                       styleClass="campo-texto"/>
                    </VBox>

                    <!-- Seletor de Perfil (DEBUG) -->
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="Perfil:" style="-fx-font-weight: 500; -fx-text-fill: #333;"/>
                        <Button fx:id="btnPerfilAutor" text="Autor" styleClass="btn-azul-claro"
                                onAction="#selecionarPerfil"/>
                        <Button fx:id="btnPerfilAvaliador" text="Avaliador" styleClass="btn-azul-claro"
                                onAction="#selecionarPerfil"/>
                        <Button fx:id="btnPerfilGerente" text="Gerente" styleClass="btn-azul-claro"
                                onAction="#selecionarPerfil"/>
                    </HBox>

                    <Label fx:id="lblMensagemErro" styleClass="msg-erro" wrapText="true"/>

                    <Button text="Entrar" styleClass="btn-primario" maxWidth="Infinity"
                            onAction="#handleLogin"/>

                    <HBox alignment="CENTER" spacing="4">
                        <Label text="Novo no LibreFox?" styleClass="label-descricao"/>
                        <Hyperlink text="Crie uma conta!" onAction="#handleIrCadastro"/>
                    </HBox>
                </VBox>
            </VBox>
        </HBox>
    </VBox>
</StackPane>